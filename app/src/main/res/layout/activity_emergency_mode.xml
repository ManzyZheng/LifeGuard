<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@color/ui_card_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <Space
                android:layout_width="82dp"
                android:layout_height="1dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/emergency_title"
                android:textColor="@color/ui_text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="82dp"
                android:layout_height="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/viewPulseDot"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_danger"
            android:text="" />

        <TextView
            android:id="@+id/tvRescueState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_white_16"
            android:padding="12dp"
            android:text="@string/emergency_rescue_processing"
            android:textColor="@color/ui_text_dark"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_white_16"
            android:padding="12dp"
            android:text="@string/emergency_steps"
            android:textColor="@color/ui_text_dark"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnAutoCall"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_danger"
            android:textAllCaps="false"
            android:text="@string/emergency_auto_call"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnShareLocation"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_orange_16"
            android:textAllCaps="false"
            android:text="@string/emergency_share_location"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenArGuide"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_orange_16"
            android:textAllCaps="false"
            android:text="@string/emergency_open_ar"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenCollaboration"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_orange_16"
            android:textAllCaps="false"
            android:text="@string/emergency_open_collaboration"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnFinishEmergency"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_safe_soft"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/emergency_finish_recovery"
            android:textAllCaps="false"
            android:textColor="@color/ui_risk_safe"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
