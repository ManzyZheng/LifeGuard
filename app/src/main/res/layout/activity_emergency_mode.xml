<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp">

            <Button
                android:id="@+id/btnTopBack"
                android:layout_width="82dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_panel"
                android:text="返回"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="急救模式已启动"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="82dp"
                android:layout_height="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/viewPulseDot"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_danger"
            android:text="" />

        <TextView
            android:id="@+id/tvRescueState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_panel"
            android:padding="12dp"
            android:text="救援状态：处理中"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel"
            android:padding="12dp"
            android:text="步骤1：检查呼吸\n步骤2：开始胸外按压\n步骤3：准备AED"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnAutoCall"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_danger"
            android:text="自动呼救 / 拨打120"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnShareLocation"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_primary"
            android:text="发送定位信息"
            android:textColor="@android:color/white"
            android:textSize="19sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenArGuide"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_primary"
            android:text="AR急救指导"
            android:textColor="@android:color/white"
            android:textSize="19sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenCollaboration"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_primary"
            android:text="协同救援"
            android:textColor="@android:color/white"
            android:textSize="19sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnFinishEmergency"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_panel"
            android:text="结束并进入系统恢复"
            android:textColor="@color/text_primary" />

    </LinearLayout>

</ScrollView>
