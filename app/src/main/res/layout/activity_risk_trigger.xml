<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_page_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/ui_card_white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp">

        <Button
            android:id="@+id/btnTopBack"
            android:layout_width="82dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:text="@string/common_back"
            android:textAllCaps="false"
            android:textColor="@color/ui_brand_orange"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/risk_trigger_title"
            android:textColor="@color/ui_text_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="82dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:text="@string/risk_trigger_detected"
        android:textColor="@color/ui_risk_high"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:text="@string/risk_trigger_confirm_help"
        android:textColor="@color/ui_text_dark"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:text="@string/risk_trigger_countdown_default"
        android:textColor="@color/ui_risk_high"
        android:textSize="80sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnIAmFine"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_button_safe_soft"
        android:text="@string/common_im_fine"
        android:textAllCaps="false"
        android:textColor="@color/ui_risk_safe"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnNeedHelp"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_button_danger"
        android:textAllCaps="false"
        android:text="@string/common_need_help"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

</LinearLayout>
