<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@color/ui_card_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <Button
                android:id="@+id/btnTopBack"
                android:layout_width="82dp"
                android:layout_height="42dp"
                android:background="@android:color/transparent"
                android:text="@string/common_back"
                android:textAllCaps="false"
                android:textColor="@color/ui_brand_orange"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/recovery_title"
                android:textColor="@color/ui_text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="82dp"
                android:layout_height="1dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_white_16"
            android:padding="12dp"
            android:text="@string/recovery_summary"
            android:textColor="@color/ui_text_dark"
            android:textSize="17sp" />

        <CheckBox
            android:id="@+id/cbNotifyContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/recovery_notify_contact"
            android:textColor="@color/ui_text_dark"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnSaveRecovery"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_orange_16"
            android:textAllCaps="false"
            android:text="@string/recovery_save_record"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_safe_soft"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/recovery_back_home"
            android:textAllCaps="false"
            android:textColor="@color/ui_risk_safe" />

    </LinearLayout>

</ScrollView>
