<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@color/ui_card_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <Button
                android:id="@+id/btnTopBack"
                android:layout_width="82dp"
                android:layout_height="42dp"
                android:background="@android:color/transparent"
                android:text="@string/common_back"
                android:textAllCaps="false"
                android:textColor="@color/ui_brand_orange"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/collaboration_title"
                android:textColor="@color/ui_text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="82dp"
                android:layout_height="1dp" />
        </LinearLayout>

        <TextView
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_qr_placeholder"
            android:gravity="center"
            android:text="@string/collaboration_qr_placeholder"
            android:textColor="@color/ui_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTaskAssign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_white_16"
            android:padding="12dp"
            android:textColor="@color/ui_text_dark"
            android:textSize="17sp" />

    </LinearLayout>

</ScrollView>
